# Mask Safety Validation API Tests
# Use with VS Code REST Client or IntelliJ HTTP Client

@baseUrl = http://localhost:5147

### Validate Single Mask Candidate
# Check if a single masked value is safe
POST {{baseUrl}}/api/mask-safety/validate
Content-Type: application/json

{
  "candidates": [
    {
      "candidateValue": "[MASKED_SSN_001]",
      "ruleId": "ssn"
    }
  ]
}

### Validate Multiple Mask Candidates
# Batch validation of multiple masked values
POST {{baseUrl}}/api/mask-safety/validate
Content-Type: application/json

{
  "candidates": [
    {
      "candidateValue": "[MASKED_SSN_001]",
      "ruleId": "ssn"
    },
    {
      "candidateValue": "[MASKED_EMAIL_002]",
      "ruleId": "email"
    },
    {
      "candidateValue": "[MASKED_PHONE_003]",
      "ruleId": "phone"
    },
    {
      "candidateValue": "[MASKED_ADDR_004]",
      "ruleId": "address"
    }
  ]
}

### Validate Empty Candidates
# Edge case: no candidates to validate
POST {{baseUrl}}/api/mask-safety/validate
Content-Type: application/json

{
  "candidates": []
}

### Validate Potentially Unsafe Values
# Test values that might leak information
POST {{baseUrl}}/api/mask-safety/validate
Content-Type: application/json

{
  "candidates": [
    {
      "candidateValue": "123-45-6789",
      "ruleId": "ssn"
    },
    {
      "candidateValue": "john.doe@email.com",
      "ruleId": "email"
    }
  ]
}

### Validate Various Rule Types
# Test different rule types
POST {{baseUrl}}/api/mask-safety/validate
Content-Type: application/json

{
  "candidates": [
    {
      "candidateValue": "[CC_REDACTED]",
      "ruleId": "credit-card"
    },
    {
      "candidateValue": "[NAME_HIDDEN]",
      "ruleId": "person-name"
    },
    {
      "candidateValue": "[DATE_REMOVED]",
      "ruleId": "date-of-birth"
    }
  ]
}
