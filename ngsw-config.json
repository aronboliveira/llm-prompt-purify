{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/ico/**", "/png/**", "/webp/**"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-health",
      "urls": ["/api/health"],
      "cacheConfig": {
        "maxSize": 1,
        "maxAge": "5m",
        "timeout": "3s",
        "strategy": "freshness"
      }
    }
  ]
}
