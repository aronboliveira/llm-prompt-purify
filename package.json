{
  "name": "llm-prompt-purify",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json --port 4201",
    "start:prod": "node dist/llm-prompt-purify/server/server.mjs",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:trace": "playwright test --trace on",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:visual": "playwright test --config=playwright.visual.config.ts",
    "test:all": "npm run test && npm run test:e2e",
    "test:ci": "jest --ci --coverage && playwright test",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:rebuild": "docker compose up -d --build",
    "docker:logs": "docker compose logs -f",
    "docker:clean": "docker compose down -v --rmi local",
    "backend:test": "docker run --rm -v \"$(pwd):/app\" -w /app mcr.microsoft.com/dotnet/sdk:8.0 dotnet test LLMPromptPurify.sln",
    "backend:build": "docker run --rm -v \"$(pwd):/app\" -w /app mcr.microsoft.com/dotnet/sdk:8.0 dotnet build LLMPromptPurify.sln",
    "deploy:netlify": "npm run build:prod && netlify deploy --prod --dir=dist/llm-prompt-purify/browser",
    "serve:ssr:llm-prompt-purify": "node dist/llm-prompt-purify/server/server.mjs",
    "generate:corpus": "python3 utils/scripts/generate_prompt_corpus.py",
    "test:mocks": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks",
    "test:mocks:en": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern '\\[en\\]'",
    "test:mocks:pt-br": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern '\\[pt-br\\]'",
    "test:mocks:es": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern '\\[es\\]'",
    "test:mocks:zh": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern '\\[zh\\]'",
    "test:mocks:formal": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'formal'",
    "test:mocks:neutral": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'neutral'",
    "test:mocks:informal": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'informal'",
    "test:mocks:lawyer": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'lawyer'",
    "test:mocks:doctor": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'doctor'",
    "test:mocks:nurse": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'nurse'",
    "test:mocks:banker": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'banker'",
    "test:mocks:accountant": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'accountant'",
    "test:mocks:hr": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'hr/'",
    "test:mocks:secretary": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'secretary'",
    "test:mocks:pharmacist": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'pharmacist'",
    "test:mocks:insurance": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'insurance_agent'",
    "test:mocks:realtor": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'realtor'",
    "test:mocks:therapist": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'therapist'",
    "test:mocks:journalist": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'journalist'",
    "test:mocks:government": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'government'",
    "test:mocks:marketing": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'marketing'",
    "test:mocks:paralegal": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'paralegal'",
    "test:mocks:tax": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'tax_preparer'",
    "test:mocks:researcher": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'researcher'",
    "test:mocks:recruiter": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'recruiter'",
    "test:mocks:teacher": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'teacher'",
    "test:mocks:social_worker": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'social_worker'",
    "test:mocks:customer_support": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'customer_support'",
    "test:mocks:developer": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'developer'",
    "test:mocks:sysadmin": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'sysadmin'",
    "test:mocks:analyst": "jest --runInBand --testPathPattern masking\\.engine\\.prompt-mocks --testNamePattern 'analyst'",
    "test:e2e:corpus": "playwright test tests/e2e/prompt-corpus-masking.spec.ts",
    "test:e2e:corpus:structure": "playwright test tests/e2e/prompt-corpus-structure.spec.ts",
    "test:scripts:corpus:structure": "bash tests/scripts/test-prompt-corpus-structure.sh",
    "test:scripts:corpus:detection": "bash tests/scripts/test-prompt-corpus-detection.sh",
    "test:python:corpus": "python3 -m pytest tests/python/test_prompt_corpus.py -v",
    "test:corpus:all": "npm run test:mocks && npm run test:scripts:corpus:structure && npm run test:python:corpus"
  },
  "private": true,
  "dependencies": {
    "@angular-devkit/build-angular": "^18.1.0",
    "@angular/cli": "^18.1.0",
    "@angular/common": "^18.1.0",
    "@angular/compiler": "^18.1.0",
    "@angular/compiler-cli": "^18.1.0",
    "@angular/core": "^18.1.0",
    "@angular/forms": "^18.1.0",
    "@angular/material": "^18.2.14",
    "@angular/platform-browser": "^18.1.0",
    "@angular/platform-browser-dynamic": "^18.1.0",
    "@angular/platform-server": "^18.1.0",
    "@angular/router": "18.2.13",
    "@angular/service-worker": "^18.2.13",
    "@angular/ssr": "^18.1.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.23.0",
    "express": "^4.18.2",
    "fuse.js": "^7.1.0",
    "jest": "^29.7.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "typescript-eslint": "^8.28.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "@types/node": "^18.18.0",
    "globals": "^17.4.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-preset-angular": "^14.5.3",
    "ts-jest": "^29.2.5",
    "typescript": "~5.5.2"
  },
  "overrides": {
    "immutable": "^5.1.1"
  }
}
