{
  "name": "llm-prompt-purify",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "start:prod": "node dist/llm-prompt-purify/server/server.mjs",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test && npm run test:e2e",
    "test:ci": "jest --ci --coverage && playwright test",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:rebuild": "docker compose up -d --build",
    "docker:logs": "docker compose logs -f",
    "docker:clean": "docker compose down -v --rmi local",
    "backend:test": "docker run --rm -v \"$(pwd):/app\" -w /app mcr.microsoft.com/dotnet/sdk:8.0 dotnet test LLMPromptPurify.sln",
    "backend:build": "docker run --rm -v \"$(pwd):/app\" -w /app mcr.microsoft.com/dotnet/sdk:8.0 dotnet build LLMPromptPurify.sln",
    "deploy:netlify": "npm run build:prod && netlify deploy --prod --dir=dist/llm-prompt-purify/browser",
    "serve:ssr:llm-prompt-purify": "node dist/llm-prompt-purify/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular-devkit/build-angular": "^18.1.0",
    "@angular/cli": "^18.1.0",
    "@angular/common": "^18.1.0",
    "@angular/compiler": "^18.1.0",
    "@angular/compiler-cli": "^18.1.0",
    "@angular/core": "^18.1.0",
    "@angular/forms": "^18.1.0",
    "@angular/material": "^18.2.14",
    "@angular/platform-browser": "^18.1.0",
    "@angular/platform-browser-dynamic": "^18.1.0",
    "@angular/platform-server": "^18.1.0",
    "@angular/router": "18.2.13",
    "@angular/service-worker": "^18.2.13",
    "@angular/ssr": "^18.1.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.23.0",
    "express": "^4.18.2",
    "fuse.js": "^7.1.0",
    "jest": "^29.7.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "typescript-eslint": "^8.28.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "@types/node": "^18.18.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-preset-angular": "^14.5.3",
    "ts-jest": "^29.2.5",
    "typescript": "~5.5.2"
  }
}
