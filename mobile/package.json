{
  "name": "llm-prompt-purify-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "prebuild": "expo prebuild",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:test:android": "detox test --configuration android.emu.debug",
    "e2e:test:ios": "detox test --configuration ios.sim.debug",
    "e2e:android": "npm run e2e:build:android && npm run e2e:test:android",
    "e2e:ios": "npm run e2e:build:ios && npm run e2e:test:ios",
    "espresso": "cd android && ./gradlew connectedAndroidTest",
    "xctest": "xcodebuild test -workspace ios/LLMPromptPurify.xcworkspace -scheme LLMPromptPurify -destination 'platform=iOS Simulator,name=iPhone 15 Pro'"
  },
  "dependencies": {
    "expo": "~52.0.0",
    "expo-clipboard": "~7.0.0",
    "expo-file-system": "~18.0.0",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.0",
    "expo-router": "~4.0.0",
    "expo-sharing": "~13.0.0",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.0",
    "fuse.js": "^7.1.0",
    "react": "18.3.1",
    "react-native": "0.76.6",
    "react-native-mmkv": "^3.2.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "~5.0.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "~15.11.0",
    "react-native-toast-message": "^2.2.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "@types/detox": "^17.14.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.3.0",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "detox": "^20.47.0",
    "eslint": "^9.23.0",
    "jest": "^29.7.0",
    "jest-circus": "^30.2.0",
    "jest-expo": "~52.0.0",
    "react-test-renderer": "18.3.1",
    "typescript": "~5.5.2"
  }
}
