{
  "manifest_version": 3,
  "name": "LLM Prompt Purifier",
  "version": "1.3.0",
  "description": "Detects sensitive data in LLM prompts and suggests safe masks. Works with ChatGPT, Claude, Gemini, Copilot, and 30+ AI chatbots.",
  "icons": { "48": "icon.png", "128": "icon.png" },
  "permissions": ["activeTab", "clipboardWrite"],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://chat.deepseek.com/*",
        "https://claude.ai/*",
        "https://console.anthropic.com/*",
        "https://gemini.google.com/*",
        "https://bard.google.com/*",
        "https://aistudio.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://www.bing.com/chat*",
        "https://www.bing.com/search*",
        "https://poe.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://labs.perplexity.ai/*",
        "https://huggingface.co/chat/*",
        "https://chat.mistral.ai/*",
        "https://console.mistral.ai/*",
        "https://labs.google/*",
        "https://you.com/*",
        "https://pi.ai/*",
        "https://character.ai/*",
        "https://beta.character.ai/*",
        "https://cohere.com/*",
        "https://coral.cohere.com/*",
        "https://dashboard.cohere.com/*",
        "https://grok.x.ai/*",
        "https://x.com/i/grok*",
        "https://twitter.com/i/grok*",
        "https://chat.lmsys.org/*",
        "https://arena.lmsys.org/*",
        "https://open-assistant.io/*",
        "https://chat.qwenlm.ai/*",
        "https://tongyi.aliyun.com/*",
        "https://chat.baichuan-ai.com/*",
        "https://yiyan.baidu.com/*",
        "https://kimi.moonshot.cn/*",
        "https://chat.zhipu.ai/*",
        "https://chatglm.cn/*",
        "https://chat.01.ai/*",
        "https://phind.com/*",
        "https://www.phind.com/*",
        "https://chat.forefront.ai/*",
        "https://app.jasper.ai/*",
        "https://chat.reka.ai/*",
        "https://writesonic.com/*",
        "https://app.copy.ai/*",
        "https://www.chatsonic.com/*",
        "https://www.meta.ai/*",
        "https://llama.meta.com/*",
        "https://ai.meta.com/*",
        "https://www.llama2.ai/*",
        "https://groq.com/*",
        "https://console.groq.com/*",
        "https://together.ai/*",
        "https://api.together.ai/*",
        "https://anyscale.com/*",
        "https://app.fireworks.ai/*",
        "https://replicate.com/*",
        "https://playground.openai.com/*",
        "https://platform.openai.com/playground*"
      ],
      "js": ["content.js"],
      "css": ["toast.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icon.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
